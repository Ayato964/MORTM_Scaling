import React, { useState, useEffect, useMemo } from 'react';
import { Settings, Cpu, Layers, Database, Calculator, Info, Save, AlertTriangle } from 'lucide-react';

const PRESETS = {
  "MORTM-A (Large)": {
    vocab_size: 650,
    d_model: 512,
    dim_feedforward: 512,
    num_heads: 8,
    d_layer: 11,
    num_experts: 6,
    topk_experts: 2,
    use_moe_decoder: true,
  },
  "MORTM-B (Deep)": {
    vocab_size: 650,
    d_model: 512,
    dim_feedforward: 2048,
    num_heads: 8,
    d_layer: 14,
    num_experts: 14,
    topk_experts: 2,
    use_moe_decoder: false, 
  },
  "MORTM-C (Compact)": {
    vocab_size: 400,
    d_model: 512,
    dim_feedforward: 2048,
    num_heads: 8,
    d_layer: 12,
    num_experts: 5,
    topk_experts: 2,
    use_moe_decoder: true,
  },
  "Custom": {
    vocab_size: 1000,
    d_model: 768,
    dim_feedforward: 3072,
    num_heads: 12,
    d_layer: 12,
    num_experts: 8,
    topk_experts: 2,
    use_moe_decoder: true,
  }
};

const Card = ({ children, className = "" }) => (
  <div className={`bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden ${className}`}>
    {children}
  </div>
);

const NumberInput = ({ label, value, onChange, min = 1, max, step = 1, description }) => (
  <div className="mb-4">
    <div className="flex justify-between items-center mb-1">
      <label className="text-sm font-medium text-slate-700 flex items-center gap-1">
        {label}
        {description && (
          <div className="group relative">
            <Info size={14} className="text-slate-400 cursor-help" />
            <div className="absolute left-0 bottom-full mb-2 hidden group-hover:block w-64 p-2 bg-slate-800 text-white text-xs rounded shadow-lg z-10 pointer-events-none">
              {description}
            </div>
          </div>
        )}
      </label>
      <span className="text-sm font-bold text-slate-900">{value}</span>
    </div>
    <input
      type="range"
      min={min}
      max={max || value * 2}
      step={step}
      value={value}
      onChange={(e) => onChange(Number(e.target.value))}
      className="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
    />
    <input
      type="number"
      min={min}
      value={value}
      onChange={(e) => onChange(Number(e.target.value))}
      className="mt-1 w-full p-1 text-sm border border-slate-300 rounded text-center"
    />
  </div>
);

const Toggle = ({ label, checked, onChange }) => (
  <div className="flex items-center justify-between mb-4 p-2 bg-slate-50 rounded-lg">
    <span className="text-sm font-medium text-slate-700">{label}</span>
    <button
      onClick={() => onChange(!checked)}
      className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 ${
        checked ? 'bg-indigo-600' : 'bg-slate-200'
      }`}
    >
      <span
        className={`inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${
          checked ? 'translate-x-6' : 'translate-x-1'
        }`}
      />
    </button>
  </div>
);

const formatParams = (num) => {
  if (num >= 1e9) return `${(num / 1e9).toFixed(2)}B`;
  if (num >= 1e6) return `${(num / 1e6).toFixed(2)}M`;
  if (num >= 1e3) return `${(num / 1e3).toFixed(2)}K`;
  return num.toLocaleString();
};

export default function MORTMParamCalc() {
  const [config, setConfig] = useState(PRESETS["MORTM-A (Large)"]);
  const [activePreset, setActivePreset] = useState("MORTM-A (Large)");

  const stats = useMemo(() => {
    const {
      vocab_size, d_model, dim_feedforward, d_layer,
      num_experts, topk_experts, use_moe_decoder
    } = config;

    // 1. Embedding Layer
    const embedding = vocab_size * d_model;

    // 2. Decoder Layer Components
    // Attention: 
    // QKV (no bias): d_model * (3 * d_model)
    // Out (bias): d_model * d_model + d_model
    const attention_params = (3 * d_model * d_model) + (d_model * d_model + d_model);

    // Normalization (3 LayerNorms per layer: norm1, norm2, norm3)
    // Each has weight + bias of size d_model
    const norm_params = (d_model * 2) * 3;

    // FFN / MoE
    // Single Expert (SwiGLU): 3 Linear layers (w1, w2, w3)
    // weight: d_model * dim_ff, bias: dim_ff
    const single_expert_params = 3 * ((d_model * dim_feedforward) + dim_feedforward);

    let ffn_total_layer = 0;
    let ffn_active_layer = 0;

    if (use_moe_decoder) {
      // Gate: num_experts * d_model
      const gate_params = num_experts * d_model;
      // All Experts
      const all_experts = num_experts * single_expert_params;
      // Shared Expert
      const shared_expert = single_expert_params;

      ffn_total_layer = gate_params + all_experts + shared_expert;
      
      // Active: Gate + TopK Experts + Shared
      const active_experts = topk_experts * single_expert_params;
      ffn_active_layer = gate_params + active_experts + shared_expert;
    } else {
      // Standard FFN (modeled as 1 expert/SwiGLU)
      ffn_total_layer = single_expert_params;
      ffn_active_layer = single_expert_params;
    }

    const layer_total = attention_params + norm_params + ffn_total_layer;
    const layer_active = attention_params + norm_params + ffn_active_layer;

    // 3. Totals across all layers
    const all_layers_total = layer_total * d_layer;
    const all_layers_active = layer_active * d_layer;

    // 4. Final Norm & Output
    const final_norm = d_model * 2;
    const output_layer = (d_model * vocab_size) + vocab_size;

    const total_params = embedding + all_layers_total + final_norm + output_layer;
    const active_params = embedding + all_layers_active + final_norm + output_layer;

    // Memory estimation (BF16 = 2 bytes)
    const memory_gb = (total_params * 2) / (1024 ** 3);

    // Calculate Sparsity (of routed experts only)
    // 0% means all experts are active (Dense equivalent)
    const sparsity = use_moe_decoder 
      ? 1.0 - (topk_experts / num_experts)
      : 0;

    return {
      total_params,
      active_params,
      layer_breakdown: {
        attention: attention_params,
        ffn: ffn_total_layer,
        norm: norm_params
      },
      component_breakdown: {
        embedding,
        layers: all_layers_total,
        output: output_layer + final_norm
      },
      memory_gb,
      sparsity
    };
  }, [config]);

  const updateConfig = (key, value) => {
    setConfig(prev => ({ ...prev, [key]: value }));
    setActivePreset("Custom");
  };

  const loadPreset = (name) => {
    setConfig(PRESETS[name]);
    setActivePreset(name);
  };

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 font-sans text-slate-800">
      <div className="max-w-6xl mx-auto">
        
        {/* Header */}
        <div className="flex items-center gap-3 mb-8">
          <div className="p-3 bg-indigo-600 rounded-lg shadow-lg">
            <Calculator className="text-white" size={24} />
          </div>
          <div>
            <h1 className="text-2xl md:text-3xl font-bold text-slate-900">MORTM Parameter Calculator</h1>
            <p className="text-slate-500 text-sm">ハイパーパラメータシミュレーター & メモリ推定</p>
          </div>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
          
          {/* Settings Panel */}
          <div className="lg:col-span-4 space-y-6">
            <Card className="p-5">
              <div className="flex items-center gap-2 mb-4 text-indigo-700 font-semibold border-b border-slate-100 pb-2">
                <Save size={18} />
                <h2>Presets</h2>
              </div>
              <div className="flex flex-wrap gap-2">
                {Object.keys(PRESETS).map(name => (
                  <button
                    key={name}
                    onClick={() => loadPreset(name)}
                    className={`px-3 py-1.5 text-xs font-medium rounded-full transition-all ${
                      activePreset === name 
                        ? 'bg-indigo-600 text-white shadow-md' 
                        : 'bg-slate-100 text-slate-600 hover:bg-slate-200'
                    }`}
                  >
                    {name}
                  </button>
                ))}
              </div>
            </Card>

            <Card className="p-5">
              <div className="flex items-center gap-2 mb-4 text-indigo-700 font-semibold border-b border-slate-100 pb-2">
                <Settings size={18} />
                <h2>Model Configuration</h2>
              </div>
              
              <NumberInput 
                label="Vocab Size" 
                value={config.vocab_size} 
                onChange={(v) => updateConfig('vocab_size', v)}
                max={5000} step={10}
                description="トークンの総数"
              />
              <NumberInput 
                label="D_Model" 
                value={config.d_model} 
                onChange={(v) => updateConfig('d_model', v)}
                max={4096} step={64}
                description="埋め込み次元数"
              />
              <NumberInput 
                label="Dim Feedforward" 
                value={config.dim_feedforward} 
                onChange={(v) => updateConfig('dim_feedforward', v)}
                max={16384} step={128}
                description="FFNの中間層次元数"
              />
              <NumberInput 
                label="Layers (d_layer)" 
                value={config.d_layer} 
                onChange={(v) => updateConfig('d_layer', v)}
                max={100}
                description="Decoderの層数"
              />
              <NumberInput 
                label="Attention Heads" 
                value={config.num_heads} 
                onChange={(v) => updateConfig('num_heads', v)}
                max={64}
                description="Multi-head Attentionのヘッド数"
              />
            </Card>

            <Card className="p-5">
              <div className="flex items-center gap-2 mb-4 text-indigo-700 font-semibold border-b border-slate-100 pb-2">
                <Cpu size={18} />
                <h2>MoE Settings</h2>
              </div>
              
              <Toggle 
                label="Use MoE Decoder"
                checked={config.use_moe_decoder}
                onChange={(v) => updateConfig('use_moe_decoder', v)}
              />

              {config.use_moe_decoder && (
                <div className="animate-in fade-in slide-in-from-top-4 duration-300">
                  <NumberInput 
                    label="Num Experts (Routed)" 
                    value={config.num_experts} 
                    onChange={(v) => updateConfig('num_experts', v)}
                    max={64}
                    description="ルーティング対象のエキスパート数（共有エキスパートは別途1つ加算されます）"
                  />
                  <NumberInput 
                    label="Top-K Experts" 
                    value={config.topk_experts} 
                    onChange={(v) => updateConfig('topk_experts', v)}
                    max={config.num_experts}
                    description="トークンごとにアクティブになるExpert数"
                  />
                  {config.num_experts === config.topk_experts && (
                     <div className="mt-2 p-3 bg-amber-50 border border-amber-200 rounded text-amber-800 text-xs flex gap-2 items-start">
                       <AlertTriangle size={14} className="mt-0.5 shrink-0" />
                       <span>
                         Warning: Routed数とTop-Kが一致しています。すべてのエキスパートが常に使用されるため、計算効率上の利点（スパース性）はありません。
                       </span>
                     </div>
                  )}
                </div>
              )}
            </Card>
          </div>

          {/* Results Panel */}
          <div className="lg:col-span-8 space-y-6">
            
            {/* Main Stats Cards */}
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <Card className="p-6 bg-gradient-to-br from-indigo-600 to-indigo-800 text-white border-none">
                <div className="flex justify-between items-start mb-2">
                  <h3 className="text-indigo-100 font-medium flex items-center gap-2">
                    <Database size={18} /> 総パラメータ数
                  </h3>
                  <span className="text-xs bg-white/20 px-2 py-1 rounded">Storage</span>
                </div>
                <div className="text-4xl font-bold mb-1">{formatParams(stats.total_params)}</div>
                <div className="text-indigo-200 text-sm">
                  Est. Size (BF16): {stats.memory_gb.toFixed(2)} GB
                </div>
              </Card>

              <Card className="p-6 bg-gradient-to-br from-emerald-500 to-emerald-700 text-white border-none">
                <div className="flex justify-between items-start mb-2">
                  <h3 className="text-emerald-100 font-medium flex items-center gap-2">
                    <ZapIcon size={18} /> アクティブパラメータ (推論時)
                  </h3>
                  <span className="text-xs bg-white/20 px-2 py-1 rounded">Compute</span>
                </div>
                <div className="text-4xl font-bold mb-1">{formatParams(stats.active_params)}</div>
                
                <div className="mt-2 text-emerald-100 text-sm flex flex-col gap-1">
                  <div className="flex justify-between border-b border-white/20 pb-1">
                     <span>Utilization</span>
                     <span>{((stats.active_params / stats.total_params) * 100).toFixed(1)}%</span>
                  </div>
                  {config.use_moe_decoder && (
                    <div className="flex justify-between pt-1">
                       <span>Sparsity (Efficiency)</span>
                       <span className={`font-bold ${stats.sparsity === 0 ? 'text-yellow-300' : 'text-white'}`}>
                         {(stats.sparsity * 100).toFixed(1)}%
                         {stats.sparsity === 0 && " (Dense)"}
                       </span>
                    </div>
                  )}
                </div>
              </Card>
            </div>

            {/* Visualizations */}
            <Card className="p-6">
              <h3 className="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2">
                <Layers size={20} className="text-indigo-600" />
                パラメータの内訳 (全層合計)
              </h3>

              {/* Bar Chart Active vs Inactive */}
              <div className="mb-8">
                <div className="flex justify-between text-sm mb-2 text-slate-600 font-medium">
                  <span>Active Parameters</span>
                  <span>Inactive (MoE Experts)</span>
                </div>
                <div className="h-8 w-full bg-slate-100 rounded-full overflow-hidden flex shadow-inner">
                  <div 
                    style={{ width: `${(stats.active_params / stats.total_params) * 100}%` }}
                    className="h-full bg-emerald-500 relative group"
                  >
                    <div className="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity" />
                  </div>
                  <div 
                    style={{ width: `${100 - (stats.active_params / stats.total_params) * 100}%` }}
                    className="h-full bg-slate-300 relative group"
                  >
                     <div className="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity" />
                  </div>
                </div>
                <div className="flex justify-between text-xs mt-2 text-slate-500">
                  <span>{formatParams(stats.active_params)}</span>
                  <span>{formatParams(stats.total_params - stats.active_params)} params saved</span>
                </div>
              </div>

              {/* Component Breakdown */}
              <div className="space-y-4">
                <h4 className="text-sm font-semibold text-slate-700 border-b pb-2">コンポーネント詳細 (1層あたり)</h4>
                
                <BreakdownItem 
                  label="Attention Mechanisms" 
                  value={stats.layer_breakdown.attention} 
                  total={stats.layer_breakdown.attention + stats.layer_breakdown.ffn + stats.layer_breakdown.norm}
                  color="bg-blue-500"
                />
                <BreakdownItem 
                  label="FeedForward / MoE" 
                  value={stats.layer_breakdown.ffn} 
                  total={stats.layer_breakdown.attention + stats.layer_breakdown.ffn + stats.layer_breakdown.norm}
                  color="bg-orange-500"
                />
                <BreakdownItem 
                  label="Normalization" 
                  value={stats.layer_breakdown.norm} 
                  total={stats.layer_breakdown.attention + stats.layer_breakdown.ffn + stats.layer_breakdown.norm}
                  color="bg-purple-500"
                />
              </div>

              <div className="mt-8 pt-6 border-t border-slate-100 text-sm text-slate-500">
                <p className="flex items-center gap-1 mb-1">
                  <Info size={14} /> 計算ロジックについて:
                </p>
                <ul className="list-disc pl-5 space-y-1">
                  <li>ExpertはSwiGLU構造 (Linear x 3) として計算しています。</li>
                  <li><strong>Num Expertsはルーティング対象のみの数です。これに加え、共有Expert (1つ) が常に加算されます。</strong></li>
                  <li>$N=K$ の場合、全てのExpertが計算に使われるため、Active = Totalとなります。</li>
                </ul>
              </div>

            </Card>
          </div>
        </div>
      </div>
    </div>
  );
}

const ZapIcon = ({ size }) => (
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    width={size} 
    height={size} 
    viewBox="0 0 24 24" 
    fill="none" 
    stroke="currentColor" 
    strokeWidth="2" 
    strokeLinecap="round" 
    strokeLinejoin="round"
  >
    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
  </svg>
);

const BreakdownItem = ({ label, value, total, color }) => (
  <div className="group">
    <div className="flex justify-between text-sm mb-1">
      <span className="text-slate-600">{label}</span>
      <span className="font-mono text-slate-900">{value.toLocaleString()}</span>
    </div>
    <div className="h-2 w-full bg-slate-100 rounded-full overflow-hidden">
      <div 
        style={{ width: `${(value / total) * 100}%` }}
        className={`h-full ${color} rounded-full transition-all duration-500 ease-out`}
      />
    </div>
  </div>
);